&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=7, celldm(1)=6.5928, celldm(3)=2.96844, nat=6, ntyp=4,
  ecutwfc=90, ecutrho=360,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  B 10.811 B_ONCV_PBE-1.2.upf
  C 12.0107 C_ONCV_PBE-1.2.upf
  Lu 174.967 Lu_ONCV_PBE-1.2.upf
  Ni 58.6934 Ni_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  Lu 0.500000 0.500000 0.000000
  Ni 0.250000 0.750000 0.500000
  Ni 0.750000 0.250000 0.500000
  B 0.142671 0.142671 0.000000
  B 0.857329 0.857329 0.000000
  C 0.000000 0.000000 0.000000
K_POINTS automatic
  24 24 24 0 0 0
