&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=7, celldm(1)=8.32804, celldm(3)=1.99665, nat=7, ntyp=2,
  ecutwfc=90, ecutrho=360,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  N 14.0067 N_ONCV_PBE-1.2.upf
  Nb 92.90638 Nb_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  Nb 0.253457 0.253457 0.000000
  Nb 0.746543 0.746543 0.000000
  Nb 0.000000 0.500000 0.500000
  Nb 0.500000 1.000000 0.500000
  N 0.250000 0.750000 0.500000
  N 0.750000 0.250000 0.500000
  N 0.000000 0.000000 0.000000
K_POINTS automatic
  24 24 24 0 0 0
