&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=1, celldm(1)=7.83193, nat=7, ntyp=2,
  ecutwfc=80, ecutrho=320,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  B 10.811 B_ONCV_PBE-1.2.upf
  Ca 40.078 Ca_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  Ca 0.500000 0.500000 0.500000
  B 0.298075 0.000000 0.000000
  B 0.000000 0.298075 0.000000
  B 0.000000 0.000000 0.298075
  B 0.000000 0.000000 0.701925
  B 0.000000 0.701925 0.000000
  B 0.701925 0.000000 0.000000
K_POINTS automatic
  24 24 24 0 0 0
