&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=4, celldm(1)=5.82846, celldm(3)=1.10298, nat=3, ntyp=2,
  ecutwfc=90, ecutrho=360,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  B 10.811 B_ONCV_PBE-1.2.upf
  Nb 92.90638 Nb_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  Nb 0.000000 0.000000 0.000000
  B 0.666667 0.333333 0.500000
  B 0.333333 0.666667 0.500000
K_POINTS automatic
  24 24 24 0 0 0
