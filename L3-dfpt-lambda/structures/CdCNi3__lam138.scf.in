&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=1, celldm(1)=7.30001, nat=5, ntyp=3,
  ecutwfc=90, ecutrho=360,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  C 12.0107 C_ONCV_PBE-1.2.upf
  Cd 112.411 Cd_ONCV_PBE-1.2.upf
  Ni 58.6934 Ni_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  Cd 0.000000 0.000000 0.000000
  Ni 0.500000 0.500000 0.000000
  Ni 0.500000 0.000000 0.500000
  Ni 0.000000 0.500000 0.500000
  C 0.500000 0.500000 0.500000
K_POINTS automatic
  24 24 24 0 0 0
