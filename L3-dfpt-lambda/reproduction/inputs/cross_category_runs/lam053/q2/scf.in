&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=2, celldm(1)=14.36036, nat=6, ntyp=2,
  ecutwfc=90, ecutrho=360,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  Ca 40.078 Ca_ONCV_PBE-1.2.upf
  Rh 102.9055 Rh_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  Ca 1.000000 0.000000 1.000000
  Ca 0.250000 0.250000 0.250000
  Rh 0.125000 0.625000 0.625000
  Rh 0.625000 0.625000 0.625000
  Rh 0.625000 0.625000 0.125000
  Rh 0.625000 0.125000 0.625000
K_POINTS automatic
  16 16 16 0 0 0
