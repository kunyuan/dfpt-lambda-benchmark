&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=12, celldm(1)=5.8128, celldm(2)=1.0, celldm(3)=1.79551, celldm(4)=0.0, nat=3, ntyp=2,
  ecutwfc=60, ecutrho=240,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  H 1.00794 H_ONCV_PBE-1.2.upf
  Sn 118.71 Sn_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  Sn 0.000000 0.000000 0.000000
  H 0.000000 0.272900 0.666690
  H 0.000000 0.000000 0.379120
K_POINTS automatic
  16 16 16 0 0 0
