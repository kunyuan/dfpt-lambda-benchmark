! QE pw.x SCF input — bcc Ta, ambient (a=3.303 A)
! Convergence params (ecutwfc/ecutrho/degauss/k-grid) are STARTING values;
! converge them yourself. Pseudopotential: free PBE from SSSP / PSlibrary.
&control
  calculation = 'scf'
  prefix      = 'ta'
  pseudo_dir  = './pseudo'
  outdir      = './out'
/
&system
  ibrav = 0
  nat   = 2
  ntyp  = 1
  ecutwfc = 60.0
  ecutrho = 480.0
  occupations = 'smearing'
  smearing    = 'methfessel-paxton'
  degauss     = 0.02
/
&electrons
  conv_thr = 1.0d-10
  mixing_beta = 0.7
/
ATOMIC_SPECIES
  Ta  180.948  Ta.pbe-spn-kjpaw_psl.1.0.0.UPF
CELL_PARAMETERS angstrom
  3.30300  0.00000  0.00000
  0.00000  3.30300  0.00000
  0.00000  0.00000  3.30300
ATOMIC_POSITIONS crystal
  Ta  0.00000  0.00000  0.00000
  Ta  0.50000  0.50000  0.50000
K_POINTS automatic
  16 16 16  0 0 0
