&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=13, celldm(1)=13.0783, celldm(2)=0.58046, celldm(3)=0.6541, celldm(4)=0.0, nat=3, ntyp=2,
  ecutwfc=60, ecutrho=240,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  Ca 40.078 Ca_ONCV_PBE-1.2.upf
  Si 28.0855 Si_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  Ca 0.000000 1.000000 0.500000
  Si 0.333154 0.666846 0.064917
  Si 0.666846 0.333154 0.935083
K_POINTS automatic
  24 24 24 0 0 0
