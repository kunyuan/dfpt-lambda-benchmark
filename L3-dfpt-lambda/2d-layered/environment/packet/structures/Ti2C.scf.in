&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=14, celldm(1)=5.79086, celldm(2)=1.00027, celldm(3)=1.70242, celldm(4)=0.27772, celldm(5)=0.2869, celldm(6)=0.49936, nat=3, ntyp=2,
  ecutwfc=90, ecutrho=360,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  C 12.0107 C_ONCV_PBE-1.2.upf
  Ti 47.867 Ti_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  Ti 0.246120 0.236130 0.765750
  Ti 0.753880 0.763870 0.234250
  C 0.500000 0.500000 0.000000
K_POINTS automatic
  24 24 24 0 0 0
