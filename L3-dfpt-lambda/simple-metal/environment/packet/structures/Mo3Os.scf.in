&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=12, celldm(1)=5.18122, celldm(2)=1.60766, celldm(3)=1.90403, celldm(4)=0.0, nat=4, ntyp=2,
  ecutwfc=90, ecutrho=360,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  Mo 95.94 Mo_ONCV_PBE-1.2.upf
  Os 190.23 Os_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  Mo 0.281114 0.000000 0.250304
  Mo 0.718886 0.000000 0.749696
  Mo 0.500000 0.500000 0.000000
  Os 0.000000 0.500000 0.500000
K_POINTS automatic
  24 24 24 0 0 0
