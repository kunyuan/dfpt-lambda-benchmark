&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=4, celldm(1)=4.73187, celldm(3)=1.63299, nat=2, ntyp=1,
  ecutwfc=60, ecutrho=240,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  Li 6.941 Li_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  Li 0.333333 0.666667 0.250000
  Li 0.666667 0.333333 0.750000
K_POINTS automatic
  24 24 24 0 0 0
