! QE pw.x SCF input — nm hcp Fe, representative @100 GPa
! Convergence params (ecutwfc/ecutrho/degauss/k-grid) are STARTING values;
! converge them yourself. Pseudopotential: free PBE from SSSP / PSlibrary.
&control
  calculation = 'scf'
  prefix      = 'fe'
  pseudo_dir  = './pseudo'
  outdir      = './out'
/
&system
  ibrav = 0
  nat   = 2
  ntyp  = 1
  ecutwfc = 60.0
  ecutrho = 480.0
  occupations = 'smearing'
  smearing    = 'methfessel-paxton'
  degauss     = 0.02
/
&electrons
  conv_thr = 1.0d-10
  mixing_beta = 0.7
/
ATOMIC_SPECIES
  Fe  55.845  Fe.pbe-spn-kjpaw_psl.1.0.0.UPF
CELL_PARAMETERS angstrom
  2.30000  0.00000  0.00000
  -1.15000  1.99186  0.00000
  0.00000  0.00000  3.68000
ATOMIC_POSITIONS crystal
  Fe  0.33333  0.66667  0.25000
  Fe  0.66667  0.33333  0.75000
K_POINTS automatic
  16 16 16  0 0 0
