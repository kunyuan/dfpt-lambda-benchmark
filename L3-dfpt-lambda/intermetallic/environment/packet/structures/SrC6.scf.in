  C 0.000000 0.333450 0.000000
  C 0.666550 0.666550 0.000000
  C 0.666550 0.000000 0.500000
  C 0.000000 0.666550 0.500000
  C 0.333450 0.333450 0.500000
  C 0.666550 0.000000 0.000000
  C 0.000000 0.666550 0.000000
  C 0.333450 0.333450 0.000000
  C 0.333450 0.000000 0.500000
  C 0.000000 0.333450 0.500000
  C 0.666550 0.666550 0.500000
K_POINTS automatic
  24 24 24 0 0 0
