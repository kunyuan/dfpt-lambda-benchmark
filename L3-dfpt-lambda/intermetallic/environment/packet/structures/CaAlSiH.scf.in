&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=4, celldm(1)=7.72917, celldm(3)=1.21684, nat=4, ntyp=4,
  ecutwfc=60, ecutrho=240,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  Al 26.9815386 Al_ONCV_PBE-1.2.upf
  Ca 40.078 Ca_ONCV_PBE-1.2.upf
  H 1.00794 H_ONCV_PBE-1.2.upf
  Si 28.0855 Si_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  Ca 0.000000 0.000000 0.007175
  Al 0.666667 0.333333 0.552151
  Si 0.333333 0.666667 0.425248
  H 0.666667 0.333333 0.908726
K_POINTS automatic
  24 24 24 0 0 0
