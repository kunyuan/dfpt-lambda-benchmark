&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=4, celldm(1)=8.21738, celldm(3)=2.09092, nat=14, ntyp=2,
  ecutwfc=80, ecutrho=320,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  C 12.0107 C_ONCV_PBE-1.2.upf
  Ca 40.078 Ca_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  Ca 0.333333 0.666667 0.250000
  Ca 0.666667 0.333333 0.750000
  C 0.333333 0.000000 0.000000
  C 0.000000 0.333333 0.000000
  C 0.666667 0.666667 0.000000
  C 0.666667 0.000000 0.500000
  C 0.000000 0.666667 0.500000
  C 0.333333 0.333333 0.500000
  C 0.666667 0.000000 0.000000
  C 0.000000 0.666667 0.000000
  C 0.333333 0.333333 0.000000
  C 0.333333 0.000000 0.500000
  C 0.000000 0.333333 0.500000
  C 0.666667 0.666667 0.500000
K_POINTS automatic
  24 24 24 0 0 0
