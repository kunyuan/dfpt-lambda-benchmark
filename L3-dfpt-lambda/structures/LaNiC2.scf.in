&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=9, celldm(1)=8.62204, celldm(2)=1.3452, celldm(3)=0.87313, nat=4, ntyp=3,
  ecutwfc=90, ecutrho=360,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  C 12.0107 C_ONCV_PBE-1.2.upf
  La 138.90547 La_ONCV_PBE-1.2.upf
  Ni 58.6934 Ni_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  La 0.370642 0.629358 0.500000
  Ni 0.985130 0.014870 0.000000
  C 0.522655 0.178427 0.000000
  C 0.821573 0.477345 0.000000
K_POINTS automatic
  24 24 24 0 0 0
