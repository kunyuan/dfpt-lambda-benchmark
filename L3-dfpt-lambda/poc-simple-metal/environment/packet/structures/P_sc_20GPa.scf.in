! QE pw.x SCF input — simple-cubic P, representative @20 GPa
! Convergence params (ecutwfc/ecutrho/degauss/k-grid) are STARTING values;
! converge them yourself. Pseudopotential: free PBE from SSSP / PSlibrary.
&control
  calculation = 'scf'
  prefix      = 'p'
  pseudo_dir  = './pseudo'
  outdir      = './out'
/
&system
  ibrav = 0
  nat   = 1
  ntyp  = 1
  ecutwfc = 60.0
  ecutrho = 480.0
  occupations = 'smearing'
  smearing    = 'methfessel-paxton'
  degauss     = 0.02
/
&electrons
  conv_thr = 1.0d-10
  mixing_beta = 0.7
/
ATOMIC_SPECIES
  P  30.974  P.pbe-n-kjpaw_psl.1.0.0.UPF
CELL_PARAMETERS angstrom
  2.38000  0.00000  0.00000
  0.00000  2.38000  0.00000
  0.00000  0.00000  2.38000
ATOMIC_POSITIONS crystal
  P  0.00000  0.00000  0.00000
K_POINTS automatic
  16 16 16  0 0 0
