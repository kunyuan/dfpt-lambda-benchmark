&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=8, celldm(1)=5.69908, celldm(2)=1.59472, celldm(3)=1.72711, nat=6, ntyp=2,
  ecutwfc=90, ecutrho=360,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  C 12.0107 C_ONCV_PBE-1.2.upf
  Mo 95.94 Mo_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  Mo 0.500000 0.256495 0.157652
  Mo 0.000000 0.756495 0.342348
  Mo 0.000000 0.243505 0.657652
  Mo 0.500000 0.743505 0.842348
  C 0.000000 0.000000 0.000000
  C 0.500000 0.500000 0.500000
K_POINTS automatic
  24 24 24 0 0 0
