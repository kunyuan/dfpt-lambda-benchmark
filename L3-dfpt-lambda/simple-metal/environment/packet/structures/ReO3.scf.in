&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=1, celldm(1)=7.16387, nat=4, ntyp=2,
  ecutwfc=90, ecutrho=360,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  O 15.9994 O_ONCV_PBE-1.2.upf
  Re 186.207 Re_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  Re 0.000000 0.000000 0.000000
  O 0.000000 0.500000 0.000000
  O 0.500000 0.000000 0.000000
  O 0.000000 0.000000 0.500000
K_POINTS automatic
  24 24 24 0 0 0
