! QE ph.x — phonons + electron-phonon (interpolated double-delta) on a coarse q-grid.
! Run AFTER scf (and a denser non-scf k-grid for the el-ph k-sum).
! Choose nq1/nq2/nq3 (coarse q-grid) and el_ph_nsigma/el_ph_sigma yourself; converge.
&inputph
  prefix       = '<prefix>'
  outdir       = './out'
  fildvscf     = 'dvscf'
  fildyn       = '<prefix>.dyn'
  electron_phonon = 'interpolated'
  el_ph_sigma  = 0.005
  el_ph_nsigma = 10
  trans        = .true.
  ldisp        = .true.
  nq1 = 4
  nq2 = 4
  nq3 = 4
/
