&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=2, celldm(1)=8.71224, nat=2, ntyp=2,
  ecutwfc=90, ecutrho=360,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  N 14.0067 N_ONCV_PBE-1.2.upf
  Zr 91.224 Zr_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  Zr 0.000000 0.000000 0.000000
  N 0.500000 0.500000 0.500000
K_POINTS automatic
  24 24 24 0 0 0
