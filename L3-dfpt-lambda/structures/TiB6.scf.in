&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=1, celldm(1)=7.7079, nat=7, ntyp=2,
  ecutwfc=90, ecutrho=360,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  B 10.811 B_ONCV_PBE-1.2.upf
  Ti 47.867 Ti_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  Ti 0.000000 0.000000 0.000000
  B 0.801246 0.500000 0.500000
  B 0.198754 0.500000 0.500000
  B 0.500000 0.801246 0.500000
  B 0.500000 0.198754 0.500000
  B 0.500000 0.500000 0.198754
  B 0.500000 0.500000 0.801246
K_POINTS automatic
  24 24 24 0 0 0
