&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=7, celldm(1)=7.4512, celldm(3)=1.66368, nat=3, ntyp=2,
  ecutwfc=80, ecutrho=320,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  C 12.0107 C_ONCV_PBE-1.2.upf
  La 138.90547 La_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  La 0.000000 0.000000 0.000000
  C 0.401169 0.401169 0.000000
  C 0.598831 0.598831 0.000000
K_POINTS automatic
  24 24 24 0 0 0
