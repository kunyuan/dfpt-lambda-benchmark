! QE pw.x SCF input — fcc La (a=5.30 A)
! Convergence params (ecutwfc/ecutrho/degauss/k-grid) are STARTING values;
! converge them yourself. Pseudopotential: free PBE from SSSP / PSlibrary.
&control
  calculation = 'scf'
  prefix      = 'la'
  pseudo_dir  = './pseudo'
  outdir      = './out'
/
&system
  ibrav = 0
  nat   = 4
  ntyp  = 1
  ecutwfc = 60.0
  ecutrho = 480.0
  occupations = 'smearing'
  smearing    = 'methfessel-paxton'
  degauss     = 0.02
/
&electrons
  conv_thr = 1.0d-10
  mixing_beta = 0.7
/
ATOMIC_SPECIES
  La  138.905  La.pbe-spfn-kjpaw_psl.1.0.0.UPF
CELL_PARAMETERS angstrom
  5.30000  0.00000  0.00000
  0.00000  5.30000  0.00000
  0.00000  0.00000  5.30000
ATOMIC_POSITIONS crystal
  La  0.00000  0.00000  0.00000
  La  0.50000  0.50000  0.00000
  La  0.50000  0.00000  0.50000
  La  0.00000  0.50000  0.50000
K_POINTS automatic
  16 16 16  0 0 0
