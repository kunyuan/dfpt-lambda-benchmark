&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=4, celldm(1)=7.57823, celldm(3)=2.5052, nat=6, ntyp=2,
  ecutwfc=60, ecutrho=240,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  Si 28.0855 Si_ONCV_PBE-1.2.upf
  Sr 87.62 Sr_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  Sr 0.000000 0.000000 0.250000
  Sr 0.000000 0.000000 0.750000
  Si 0.666667 0.333333 0.467883
  Si 0.333333 0.666667 0.967883
  Si 0.333333 0.666667 0.532117
  Si 0.666667 0.333333 0.032117
K_POINTS automatic
  24 24 24 0 0 0
