&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=4, celldm(1)=6.03888, celldm(3)=4.36798, nat=6, ntyp=2,
  ecutwfc=90, ecutrho=360,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  Mo 95.94 Mo_ONCV_PBE-1.2.upf
  S 32.065 S_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  Mo 0.333333 0.666667 0.250000
  Mo 0.666667 0.333333 0.750000
  S 0.333333 0.666667 0.638020
  S 0.666667 0.333333 0.361980
  S 0.666667 0.333333 0.138020
  S 0.333333 0.666667 0.861980
K_POINTS automatic
  24 24 24 0 0 0
