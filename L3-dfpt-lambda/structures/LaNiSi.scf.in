&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=7, celldm(1)=7.90882, celldm(3)=3.33844, nat=6, ntyp=3,
  ecutwfc=90, ecutrho=360,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  La 138.90547 La_ONCV_PBE-1.2.upf
  Ni 58.6934 Ni_ONCV_PBE-1.2.upf
  Si 28.0855 Si_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  La 0.751826 0.751826 0.000000
  La 0.501826 0.001826 0.500000
  Si 0.331811 0.331811 0.000000
  Si 0.081811 0.581811 0.500000
  Ni 0.912640 0.412640 0.500000
  Ni 0.162640 0.162640 0.000000
K_POINTS automatic
  24 24 24 0 0 0
