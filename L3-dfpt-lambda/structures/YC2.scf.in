&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=7, celldm(1)=6.94871, celldm(3)=1.6829, nat=3, ntyp=2,
  ecutwfc=90, ecutrho=360,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  C 12.0107 C_ONCV_PBE-1.2.upf
  Y 88.90585 Y_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  Y 0.000000 0.000000 0.000000
  C 0.395100 0.395100 0.000000
  C 0.604900 0.604900 1.000000
K_POINTS automatic
  24 24 24 0 0 0
