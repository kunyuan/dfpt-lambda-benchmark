&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=6, celldm(1)=5.73154, celldm(3)=1.09397, nat=8, ntyp=2,
  ecutwfc=60, ecutrho=240,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  Ge 72.64 Ge_ONCV_PBE-1.2.upf
  H 1.00794 H_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  Ge 0.500000 0.000000 0.500000
  Ge 0.000000 0.500000 0.000000
  H 0.000000 0.000000 0.250000
  H 0.000000 0.000000 0.750000
  H 0.500000 0.224400 0.000000
  H 0.775600 0.500000 0.500000
  H 0.224400 0.500000 0.500000
  H 0.500000 0.775600 0.000000
K_POINTS automatic
  16 16 16 0 0 0
