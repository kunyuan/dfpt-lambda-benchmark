&control
  calculation='scf', prefix='x', pseudo_dir='./pseudo', outdir='./out'
/
&system
  ibrav=4, celldm(1)=6.46364, celldm(3)=1.69059, nat=4, ntyp=1,
  ecutwfc=60, ecutrho=240,
  occupations='smearing', smearing='methfessel-paxton', degauss=0.02, nspin=1
/
&electrons
  conv_thr=1.0d-10, mixing_beta=0.7
/
ATOMIC_SPECIES
  H 1.00794 H_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS crystal
  H 0.333333 0.666667 0.814870
  H 0.666667 0.333333 0.314870
  H 0.666667 0.333333 0.185130
  H 0.333333 0.666667 0.685130
K_POINTS automatic
  24 24 24 0 0 0
